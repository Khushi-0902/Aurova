# =============================================================================
# THIS FILE IS NOT LOADED BY NEXT.JS — it is only a template for humans/git.
# Copy these variables into ".env.local" in the same folder, fill values,
# then restart "npm run dev". Never commit real secrets to git.
# =============================================================================

# --- Auth.js (NextAuth) ---
# Generate: openssl rand -base64 32
AUTH_SECRET=

# Must match the URL you open in the browser (no trailing slash).
# Local: http://localhost:3000   Production: https://your-domain.com
AUTH_URL=http://localhost:3000

# --- Google "Continue with Google" (put real values in .env.local only) ---
# 1) Open https://console.cloud.google.com/ → select or create a project.
# 2) APIs & Services → OAuth consent screen → choose "External" (or Internal for Workspace) → create.
#    Add scopes: openid, email, profile (defaults are fine for sign-in).
# 3) APIs & Services → Credentials → "+ Create credentials" → "OAuth client ID".
#    Application type: Web application.
# 4) Authorized JavaScript origins:
#      http://localhost:3000
#    (Add your production URL later, e.g. https://your-domain.com)
# 5) Authorized redirect URIs (must match exactly, including path):
#      http://localhost:3000/api/auth/callback/google
#    (Production: https://your-domain.com/api/auth/callback/google)
# 6) Create → copy "Client ID" and "Client secret" into .env.local below.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Email OTP (optional locally; OTP prints in terminal if unset) ---
# https://resend.com — verify a domain or use their test sender for dev.
RESEND_API_KEY=
RESEND_FROM="Aurova <onboarding@resend.dev>"
